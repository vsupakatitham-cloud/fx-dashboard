{
  "manifest_version": 3,
  "name": "KTB FX — daily rate capture",
  "version": "1.10.0",
  "description": "Captures Mastercard network rates and KBank K-Journey debit rates once a day from your real Chrome session and posts them to the local fx-dashboard collector.",
  "permissions": [
    "alarms",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://www.mastercard.com/*",
    "https://www.kasikornbank.com/*",
    "http://localhost:8777/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.mastercard.com/global/en/personal/get-support/currency-exchange-rate-converter.html*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.kasikornbank.com/th/personal/Debit-Card/Pages/exchange-rate.aspx*"
      ],
      "js": [
        "kbank.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Capture FX rates now (Mastercard + K-Journey)"
  }
}
